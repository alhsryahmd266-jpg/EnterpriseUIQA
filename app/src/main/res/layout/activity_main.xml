<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enterprise UI QA"
            android:textColor="#58A6FF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Automation Framework v1.0.5"
            android:textColor="#8B949E"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>

        <!-- Accessibility Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="جاري الفحص..."
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenAccessibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="فتح إعدادات إمكانية الوصول"
            android:textColor="#0D1117"
            android:backgroundTint="#58A6FF"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="24dp"/>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#30404D" android:layout_marginBottom="20dp"/>

        <!-- ══ قسم الهدف اليدوي ══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نقطة الضغط اليدوية"
            android:textColor="#58A6FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اضغط الزر ثم المس الشاشة لتحديد المكان"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvManualTarget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="لم يُحدَّد هدف بعد"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="#161B22"
            android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 حدد نقطة الضغط"
                android:textColor="#0D1117"
                android:backgroundTint="#58A6FF"
                android:paddingHorizontal="20dp"
                android:layout_marginEnd="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕ مسح"
                android:textColor="#0D1117"
                android:backgroundTint="#6E7681"
                android:paddingHorizontal="16dp"/>
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#30404D"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"/>

        <!-- ══ قسم المسح التلقائي ════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="المسح التلقائي — اكتشاف الجسم البشري"
            android:textColor="#3FB950"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MediaProjection + ML Kit Pose Detection"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartCapture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶  بدء المسح"
                android:textColor="#0D1117"
                android:backgroundTint="#3FB950"
                android:paddingHorizontal="24dp"
                android:layout_marginEnd="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStopCapture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏹  إيقاف"
                android:textColor="#0D1117"
                android:backgroundTint="#F85149"
                android:paddingHorizontal="24dp"
                android:enabled="false"/>
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#30404D"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"/>

        <!-- ══ قسم DPU ════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="وحدة معالجة البيانات — DPU"
            android:textColor="#F0A500"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ProximitySorter + DynamicOffset Algorithm"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRunDpu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶  تشغيل اختبار DPU"
            android:textColor="#0D1117"
            android:backgroundTint="#F0A500"
            android:paddingHorizontal="32dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvDpu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="اضغط الزر لتشغيل الاختبار..."
            android:textColor="#C9D1D9"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#161B22"
            android:padding="16dp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
